{
  "schemaVersion": 1,
  "jobType": "jsonplaceholder-todos-memory",
  "http": {
    "baseUrl": "https://jsonplaceholder.typicode.com"
  },
  "scenario": {
    "steps": [
      {
        "id": "list-open-todos",
        "action": "jsonplaceholder.list-user-todos",
        "payload": {
          "userId": 4,
          "completed": false
        }
      },
      {
        "id": "recall-user-id",
        "action": "flow.sleep",
        "payload": {
          "duration": "100ms"
        }
      },
      {
        "id": "use-todo-data",
        "action": "jsonplaceholder.get-user",
        "payload": {
          "id": "${jsonpath(step:list-open-todos, $[0].userId)}"
        }
      },
      {
        "id": "list-posts",
        "action": "jsonplaceholder.list-posts",
        "payload": {
          "userId": "${step.use-todo-data.response.id}",
          "limit": 3
        }
      }
    ]
  }
}
