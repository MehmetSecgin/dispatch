{
  "schemaVersion": 1,
  "jobType": "jsonplaceholder-seed-user-1-reference",
  "http": {
    "baseUrl": "https://jsonplaceholder.typicode.com"
  },
  "scenario": {
    "steps": [
      {
        "id": "user",
        "action": "jsonplaceholder.get-user",
        "payload": {
          "id": 1
        }
      },
      {
        "id": "store-user",
        "action": "memory.store",
        "payload": {
          "namespace": "jsonplaceholder-reference",
          "key": "users.user-1",
          "value": {
            "payload": "${step.user.response}",
            "meta": {
              "cachedAt": "${run.startedAt}",
              "source": "jsonplaceholder.get-user",
              "sourceKey": "1"
            }
          }
        }
      }
    ]
  }
}
